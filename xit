def now() -> int:
    return int(time.time())


def resolve_profiles_root() -> Path:
    env_dir = os.environ.get("XIT_PROFILE_DIR", "").strip()
    if env_dir:
        root = Path(env_dir).expanduser()
    else:
        cwd_root = Path.cwd() / ".xprofiles"
        root = cwd_root if cwd_root.exists() else Path.home() / ".xprofiles"
    root.mkdir(mode=0o700, parents=True, exist_ok=True)
    try:
        os.chmod(root, 0o700)
    except OSError:
        pass
    return root


def sanitize_profile(profile: str) -> str:
    safe = "".join(c for c in profile if c.isalnum() or c in ("-", "_", ".")).strip(".")
    if not safe:
        raise SystemExit("profile name is empty after sanitization")
    return safe


def profile_root(profile: str) -> Path:
    return resolve_profiles_root() / sanitize_profile(profile)


def profile_browser_path(profile: str) -> Path:
    return profile_root(profile) / "firefox"


def profile_browser_dir(profile: str) -> Path:
    path = profile_browser_path(profile)
    path.mkdir(mode=0o700, parents=True, exist_ok=True)
    return path


def profile_meta_path(profile: str) -> Path:
    return profile_root(profile) / "meta.json"


def load_meta(profile: str) -> dict | None:
    path = profile_meta_path(profile)
    if not path.exists():
        return None
    with path.open("r", encoding="utf-8") as fh:
        return json.load(fh)


def save_meta(profile: str, payload: dict) -> Path:
    root = profile_root(profile)
    root.mkdir(mode=0o700, parents=True, exist_ok=True)
    path = profile_meta_path(profile)
    tmp = path.with_suffix(".json.tmp")
    data = json.dumps(payload, indent=2, sort_keys=True) + "\n"
    fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    with os.fdopen(fd, "w", encoding="utf-8") as fh:
        fh.write(data)
    os.replace(tmp, path)
    try:
        os.chmod(path, 0o600)
    except OSError:
        pass
    return path


def delete_profile(profile: str) -> None:
    root = profile_root(profile)
    if root.exists():
        shutil.rmtree(root)


def rename_profile(old_profile: str, new_profile: str) -> None:
    old_root = profile_root(old_profile)
    if not old_root.exists():
        raise SystemExit(f"profile {old_profile} does not exist")

    new_root = profile_root(new_profile)
    if new_root.exists():
        raise SystemExit(f"profile {new_profile} already exists")

    old_root.rename(new_root)

    meta = load_meta(new_profile)
    if meta is not None:
        meta["profile"] = sanitize_profile(new_profile)
        meta["browser_dir"] = str(profile_browser_path(new_profile))
        meta["updated_at"] = now()
        save_meta(new_profile, meta)


def firefox_binary() -> str:
    env = os.environ.get("XIT_FIREFOX_BINARY", "").strip()
    if env:
        return env
    for candidate in ("firefox", "firefox-esr", "fennec"):
        found = shutil.which(candidate)
        if found:
            return found
    raise SystemExit(
        "could not find a Firefox binary. Set XIT_FIREFOX_BINARY to the browser path."
    )


def geckodriver_binary() -> str:
    env = os.environ.get("XIT_GECKODRIVER", "").strip()
    if env:
        return env
    found = shutil.which("geckodriver")
    if found:
        return found
    raise SystemExit("could not find geckodriver. Set XIT_GECKODRIVER to the driver path.")


def ensure_display() -> None:
    if os.environ.get("DISPLAY", "").strip():
        return

    termux_x11 = shutil.which("termux-x11")
    if not termux_x11:
        raise SystemExit(
            "no DISPLAY is set and termux-x11 is not installed.\n"
            "Start an X11 session and export DISPLAY=:0 before running xit."
        )

    try:
        subprocess.run(
            ["am", "start", "-n", "com.termux.x11/com.termux.x11.MainActivity"],
            check=False,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except FileNotFoundError:
        pass

    try:
        subprocess.Popen(
            [termux_x11, TERMUX_X11_DISPLAY],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except OSError as exc:
        raise SystemExit(
            "failed to start termux-x11 automatically. "
            "Start Termux:X11 manually and export DISPLAY=:0.\n"
            f"{exc}"
        ) from exc

    os.environ["DISPLAY"] = TERMUX_X11_DISPLAY
    time.sleep(2)


def launch_manual_firefox(profile: str, url: str):
    ensure_display()
    cmd = [
        firefox_binary(),
        "--new-instance",
        "--profile",
        str(profile_browser_dir(profile)),
        url,
    ]
    try:
        return subprocess.Popen(cmd)
    except OSError as exc:
        raise SystemExit(f"failed to launch Firefox for manual login: {exc}") from exc


def build_driver(profile: str, headless: bool = False) -> webdriver.Firefox:
    if not headless:
        ensure_display()
    options = Options()
    options.binary_location = firefox_binary()
    options.add_argument("-profile")
    options.add_argument(str(profile_browser_dir(profile)))
    options.add_argument("--new-instance")
    if headless:
        options.add_argument("-headless")
    options.set_preference("dom.webnotifications.enabled", False)
    options.set_preference("browser.startup.homepage", "about:blank")
    options.set_preference("browser.shell.checkDefaultBrowser", False)
    options.set_preference("browser.aboutConfig.showWarning", False)
    options.set_preference("toolkit.telemetry.reportingpolicy.firstRun", False)
    service = Service(geckodriver_binary())
    try:
        driver = webdriver.Firefox(service=service, options=options)
        driver.set_window_size(1280, 960)
        return driver
    except WebDriverException as exc:
        raise SystemExit(
            "failed to launch Firefox via Selenium. "
            "Check that Firefox and geckodriver are installed and compatible.\n"
            f"{exc}"
        ) from exc


def has_css(driver: webdriver.Firefox, selector: str) -> bool:
    return bool(driver.execute_script("return !!document.querySelector(arguments[0]);", selector))


def is_logged_in(driver: webdriver.Firefox) -> bool:
    selectors = (
        "[data-testid='AppTabBar_Home_Link']",
        "[data-testid='SideNav_NewTweet_Button']",
        "[data-testid='SideNav_NewTweet_Button_Button']",
        "[data-testid='tweetTextarea_0']",
        "a[href='/compose/post']",
    )
    for selector in selectors:
        try:
            if has_css(driver, selector):
                return True
        except WebDriverException:
            continue
    current = driver.current_url
    return "/home" in current and "/i/flow/login" not in current


def wait_until_logged_in(driver: webdriver.Firefox, timeout_seconds: int) -> bool:
    deadline = time.time() + max(timeout_seconds, 1)
    while True:
        try:
            if is_logged_in(driver):
                return True
        except WebDriverException:
            pass
        if time.time() >= deadline:
            return False
        time.sleep(2)


def cookie_names(cookies: list[dict]) -> set[str]:
    return {str(cookie.get("name", "")).strip() for cookie in cookies}


def is_x_domain(domain: str) -> bool:
    clean = domain.strip().lstrip("#").lstrip(".").lower()
    if clean.startswith("httponly_"):
        clean = clean[len("httponly_") :]
    return any(clean.endswith(item) for item in X_DOMAINS)


def normalize_same_site(value: object) -> str | None:
    if value in (None, ""):
        return None
    lowered = str(value).strip().lower().replace("-", "_")
    mapping = {
        "none": "None",
        "no_restriction": "None",
        "lax": "Lax",
        "strict": "Strict",
        "unspecified": None,
    }
    if lowered not in mapping:
        return None
    return mapping[lowered]


def stringify_storage_value(value: object) -> str:
    if isinstance(value, str):
        return value
    return json.dumps(value, sort_keys=True, separators=(",", ":"))


def normalize_local_storage_payload(data: object) -> dict[str, str]:
    if isinstance(data, dict):
        if "origins" in data:
            return extract_local_storage_from_origins(data["origins"])
        if "localStorage" in data:
            return normalize_local_storage_payload(data["localStorage"])
        if "name" in data and "value" in data:
            return {str(data["name"]): stringify_storage_value(data["value"])}
        return {str(key): stringify_storage_value(value) for key, value in data.items()}

    if isinstance(data, list):
        storage = {}
        for item in data:
            if not isinstance(item, dict) or "name" not in item or "value" not in item:
                raise ValueError("local storage entries must be objects with name and value")
            storage[str(item["name"])] = stringify_storage_value(item["value"])
        return storage

    raise ValueError("local storage must be a JSON object or list")


def extract_local_storage_from_origins(origins: object) -> dict[str, str]:
    if not isinstance(origins, list):
        raise ValueError("origins must be a JSON list")
    storage: dict[str, str] = {}
    for origin in origins:
        if not isinstance(origin, dict):
            continue
        origin_name = str(origin.get("origin", "")).rstrip("/")
        if origin_name not in ("https://x.com", "https://twitter.com"):
            continue
        items = origin.get("localStorage", [])
        if not isinstance(items, list):
            continue
        for item in items:
            if not isinstance(item, dict) or "name" not in item or "value" not in item:
                continue
            storage[str(item["name"])] = stringify_storage_value(item["value"])
    return storage


def normalize_cookie(cookie: dict, default_domain: str = "x.com") -> dict:
    name = str(cookie.get("name", "")).strip()
    if not name:
        raise ValueError("cookie is missing a name")

    value = str(cookie.get("value", ""))
    domain_value = str(cookie.get("domain", "")).strip()
    domain = domain_value.lstrip("#").lstrip(".")
    if domain.lower().startswith("httponly_"):
        domain = domain[len("httponly_") :]
    if not domain:
        domain = default_domain
    elif is_x_domain(domain):
        domain = "x.com"

    normalized = {
        "name": name,
        "value": value,
        "domain": domain,
        "path": str(cookie.get("path", "/") or "/"),
        "secure": bool(cookie.get("secure", True)),
    }

    http_only = cookie.get("httpOnly", cookie.get("http_only"))
    if http_only is not None:
        normalized["httpOnly"] = bool(http_only)

    expiry = cookie.get("expiry", cookie.get("expires", cookie.get("expirationDate")))
    if expiry not in (None, "", 0, "0"):
        try:
            normalized["expiry"] = int(float(str(expiry)))
        except ValueError:
            pass

    same_site = normalize_same_site(cookie.get("sameSite", cookie.get("same_site")))
    if same_site:
        normalized["sameSite"] = same_site

    return normalized


def parse_cookie_pairs(raw: str) -> list[dict]:
    header = raw.strip()
    if not header:
        return []
    if header.lower().startswith("cookie:"):
        header = header.split(":", 1)[1].strip()
    cookies = []
    for chunk in header.split(";"):
        piece = chunk.strip()
        if not piece or "=" not in piece:
            continue
        name, value = piece.split("=", 1)
        cookies.append(
            normalize_cookie(
                {
                    "name": name.strip(),
                    "value": value.strip(),
                    "domain": "x.com",
                    "path": "/",
                    "secure": True,
                }
            )
        )
    return cookies


def parse_curl_command(raw: str) -> dict:
    try:
        tokens = shlex.split(raw, posix=True)
    except ValueError as exc:
        raise ValueError(f"could not parse the pasted curl command: {exc}") from exc

    if not tokens or Path(tokens[0]).name != "curl":
        raise ValueError("not a curl command")

    headers: dict[str, str] = {}
    cookie_override = ""
    index = 0
    while index < len(tokens):
        token = tokens[index]
        next_value = tokens[index + 1] if index + 1 < len(tokens) else None

        if token in ("-H", "--header") and next_value is not None:
            header = next_value
            index += 2
        elif token.startswith("--header="):
            header = token.split("=", 1)[1]
            index += 1
        elif token.startswith("-H") and token != "-H":
            header = token[2:]
            index += 1
        elif token in ("-b", "--cookie") and next_value is not None:
            cookie_override = next_value
            index += 2
            continue
        elif token.startswith("--cookie="):
            cookie_override = token.split("=", 1)[1]
            index += 1
            continue
        else:
            index += 1
            continue

        name, sep, value = header.partition(":")
        if sep:
            headers[name.strip().lower()] = value.strip()

    cookie_header = cookie_override or headers.get("cookie", "")
    cookies = parse_cookie_pairs(cookie_header)
    if not cookies:
        raise ValueError("the pasted curl command does not include a Cookie header")

    csrf = headers.get("x-csrf-token", "").strip()
    if csrf and "ct0" not in cookie_names(cookies):
        cookies.append(
            normalize_cookie(
                {
                    "name": "ct0",
                    "value": csrf,
                    "domain": "x.com",
                    "path": "/",
                    "secure": True,
                }
            )
        )

    return {
        "cookies": cookies,
        "local_storage": {},
        "source": "curl",
        "user_agent": headers.get("user-agent"),
    }


def parse_netscape_cookie_file(raw: str) -> dict:
    cookies = []
    for line in raw.splitlines():
        entry = line.strip()
        if not entry:
            continue

        http_only = False
        if entry.startswith("#HttpOnly_"):
            http_only = True
            entry = entry[len("#HttpOnly_") :]
        elif entry.startswith("#"):
            continue

        parts = entry.split("\t")
        if len(parts) != 7:
            continue

        domain, _, path, secure, expiry, name, value = parts
        if not is_x_domain(domain):
            continue
        cookie = normalize_cookie(
            {
                "domain": domain,
                "path": path,
                "secure": secure.upper() == "TRUE",
                "expiry": expiry,
                "name": name,
                "value": value,
                "httpOnly": http_only,
            }
        )
        cookies.append(cookie)

    if not cookies:
        raise ValueError("not a Netscape cookie file")

    return {"cookies": cookies, "local_storage": {}, "source": "netscape"}


def parse_json_session_payload(raw: str) -> dict:
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as exc:
        raise ValueError("not JSON session data") from exc

    local_storage: dict[str, str] = {}
    cookies_source: object

    if isinstance(data, list):
        cookies_source = data
    elif isinstance(data, dict):
        if "session" in data and isinstance(data["session"], dict):
            nested = data["session"]
            cookies_source = nested.get("cookies", [])
            local_storage.update(
                normalize_local_storage_payload(nested.get("local_storage", {}))
                if nested.get("local_storage")
                else {}
            )
        elif "cookies" in data:
            cookies_source = data["cookies"]
        elif "name" in data and "value" in data:
            cookies_source = [data]
        else:
            raise ValueError("JSON payload does not contain cookies")

        if "origins" in data:
            local_storage.update(extract_local_storage_from_origins(data["origins"]))
        if "local_storage" in data and data["local_storage"]:
            local_storage.update(normalize_local_storage_payload(data["local_storage"]))
        if "localStorage" in data and data["localStorage"]:
            local_storage.update(normalize_local_storage_payload(data["localStorage"]))
    else:
        raise ValueError("JSON payload must be an object or list")

    if not isinstance(cookies_source, list):
        raise ValueError("cookies must be a JSON list")

    cookies = []
    for item in cookies_source:
        if not isinstance(item, dict):
            continue
        domain = str(item.get("domain", "")).strip()
        if domain and not is_x_domain(domain):
            continue
        cookies.append(normalize_cookie(item))

    if not cookies:
        raise ValueError("JSON payload does not contain any X cookies")

    return {"cookies": cookies, "local_storage": local_storage, "source": "json"}


def parse_cookie_header_payload(raw: str) -> dict:
    cookie_line = ""
    lines = [line.strip() for line in raw.splitlines() if line.strip()]
    for line in lines:
        if line.lower().startswith("cookie:"):
            cookie_line = line
            break
    cookies = parse_cookie_pairs(cookie_line or raw)
    if not cookies:
        raise ValueError("not a cookie header")
    return {"cookies": cookies, "local_storage": {}, "source": "cookie-header"}


def parse_local_storage_json(raw: str) -> dict[str, str]:
    text = raw.strip()
    if not text:
        return {}
    try:
        data = json.loads(text)
    except json.JSONDecodeError as exc:
        raise ValueError(f"local storage must be valid JSON: {exc}") from exc
    return normalize_local_storage_payload(data)


def parse_session_capture(raw_session: str, raw_local_storage: str) -> dict:
    session_text = raw_session.strip()
    if not session_text:
        raise ValueError("paste a curl command, Cookie header, JSON export, or Netscape cookie file")

    parsers = (
        parse_curl_command,
        parse_json_session_payload,
        parse_netscape_cookie_file,
        parse_cookie_header_payload,
    )
    last_error: ValueError | None = None
    capture = None
    for parser in parsers:
        try:
            capture = parser(session_text)
            break
        except ValueError as exc:
            last_error = exc

    if capture is None:
        message = str(last_error) if last_error else "could not parse the submitted session data"
        raise ValueError(message)

    capture["local_storage"] = {
        **capture.get("local_storage", {}),
        **parse_local_storage_json(raw_local_storage),
    }
    capture["captured_at"] = now()

    names = cookie_names(capture["cookies"])
    missing = sorted(SESSION_COOKIE_NAMES - names)
    if missing:
        raise ValueError(
            "missing required X cookies: "
            + ", ".join(missing)
            + ". Capture from a logged-in https://x.com request."
        )
    return capture


