def capture_session_via_localhost(profile: str, host: str, port: int, timeout_seconds: int) -> dict:
    state = {
        "capture": None,
        "error": "",
        "session_text": "",
        "storage_text": "",
    }

    class Handler(BaseHTTPRequestHandler):
        def do_GET(self) -> None:
            if self.path != "/":
                self.send_error(HTTPStatus.NOT_FOUND)
                return
            self.respond(
                build_capture_page(
                    profile,
                    state["session_text"],
                    state["storage_text"],
                    error=state["error"],
                )
            )

        def do_POST(self) -> None:
            if self.path != "/capture":
                self.send_error(HTTPStatus.NOT_FOUND)
                return

            length = int(self.headers.get("Content-Length", "0"))
            payload = self.rfile.read(length).decode("utf-8", errors="replace")
            form = parse_qs(payload, keep_blank_values=True)
            state["session_text"] = form.get("session_payload", [""])[0]
            state["storage_text"] = form.get("local_storage", [""])[0]

            try:
                state["capture"] = parse_session_capture(
                    state["session_text"],
                    state["storage_text"],
                )
            except ValueError as exc:
                state["error"] = str(exc)
                self.respond(
                    build_capture_page(
                        profile,
                        state["session_text"],
                        state["storage_text"],
                        error=state["error"],
                    ),
                    status=HTTPStatus.BAD_REQUEST,
                )
                return

            state["error"] = ""
            self.respond(
                build_capture_page(
                    profile,
                    "",
                    "",
                    success=state["capture"],
                )
            )

        def log_message(self, format: str, *args) -> None:
            return

        def respond(self, body: str, status: HTTPStatus = HTTPStatus.OK) -> None:
            payload = body.encode("utf-8")
            self.send_response(int(status))
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)

    try:
        server = HTTPServer((host, port), Handler)
    except OSError as exc:
        raise SystemExit(f"failed to start the local auth server on {host}:{port}: {exc}") from exc

    server.timeout = 1
    actual_host, actual_port = server.server_address[:2]
    display_host = "127.0.0.1" if actual_host == "0.0.0.0" else actual_host

    print(f"localhost auth capture for {profile}", flush=True)
    print(f"open this URL in a browser: http://{display_host}:{actual_port}/", flush=True)
    if actual_host == "0.0.0.0":
        print(
            "replace 127.0.0.1 with this machine's LAN IP if you are opening it from another device",
            flush=True,
        )
    print(
        "paste a logged-in X request as curl, a Cookie header, or an exported cookie file",
        flush=True,
    )
    print("press Ctrl+C here to cancel", flush=True)

    deadline = time.time() + max(timeout_seconds, 1)
    try:
        while time.time() < deadline and state["capture"] is None:
            server.handle_request()
    except KeyboardInterrupt as exc:
        raise SystemExit("auth capture cancelled") from exc
    finally:
        server.server_close()

    if state["capture"] is not None:
        return state["capture"]
    raise SystemExit(
        f"timed out waiting for localhost auth capture after {timeout_seconds} seconds. "
        "Re-run the command and submit the session data before the timeout."
    )


def load_stored_session(profile: str) -> dict | None:
    meta = load_meta(profile) or {}
    session = meta.get("session")
    if not isinstance(session, dict):
        return None
    cookies = session.get("cookies")
    if not isinstance(cookies, list) or not cookies:
        return None
    return session


def restore_session(driver: webdriver.Firefox, session: dict) -> bool:
    cookies = session.get("cookies", [])
    local_storage = session.get("local_storage", {})
    if not cookies and not local_storage:
        return False

    driver.get(ROOT_URL)
    try:
        driver.delete_all_cookies()
    except WebDriverException:
        pass

    for cookie in cookies:
        driver_cookie = {
            "name": cookie["name"],
            "value": cookie["value"],
            "path": cookie.get("path", "/"),
            "secure": bool(cookie.get("secure", True)),
        }
        if cookie.get("domain"):
            driver_cookie["domain"] = str(cookie["domain"]).lstrip(".")
        if "httpOnly" in cookie:
            driver_cookie["httpOnly"] = bool(cookie["httpOnly"])
        if cookie.get("expiry"):
            driver_cookie["expiry"] = int(cookie["expiry"])
        if cookie.get("sameSite"):
            driver_cookie["sameSite"] = cookie["sameSite"]

        try:
            driver.add_cookie(driver_cookie)
        except WebDriverException:
            fallback_cookie = dict(driver_cookie)
            fallback_cookie.pop("domain", None)
            try:
                driver.add_cookie(fallback_cookie)
            except WebDriverException as exc:
                raise SystemExit(
                    f"failed to restore stored cookie {driver_cookie['name']}: {exc}"
                ) from exc

    if isinstance(local_storage, dict) and local_storage:
        driver.execute_script(
            """
            for (const [key, value] of Object.entries(arguments[0])) {
              window.localStorage.setItem(key, value);
            }
            """,
            local_storage,
        )

    driver.get(HOME_URL)
    return True


def wait_for_login(
    driver: webdriver.Firefox,
    profile: str,
    timeout_seconds: int,
    allow_manual_login: bool,
    session_payload: dict | None = None,
) -> None:
    probe_seconds = min(timeout_seconds, LOGIN_PROBE_SECONDS)

    driver.get(HOME_URL)
    if wait_until_logged_in(driver, probe_seconds):
        return

    active_session = session_payload or load_stored_session(profile)
    if active_session:
        restore_session(driver, active_session)
        if wait_until_logged_in(driver, probe_seconds):
            return

    if not allow_manual_login:
        raise SystemExit(
            f"no logged-in session found for {profile}.\n"
            f"Run `xit auth {profile}` to capture a session via localhost or "
            f"`xit auth {profile} --manual-browser` for the old visible-browser flow."
        )

    driver.get(LOGIN_URL)
    print("complete the login in the opened browser window", flush=True)
    print("the session will be cached under:", profile_browser_path(profile), flush=True)
    if wait_until_logged_in(driver, timeout_seconds):
        return
    raise SystemExit(
        f"timed out waiting for X login after {timeout_seconds} seconds. "
        "Re-run the command and complete login in the browser."
    )


def wait_clickable(driver: webdriver.Firefox, selectors: list[str], timeout_seconds: int):
    deadline = time.time() + timeout_seconds
    last_error = None
    while time.time() < deadline:
        for selector in selectors:
            try:
                element = WebDriverWait(driver, 1).until(
                    EC.element_to_be_clickable((By.CSS_SELECTOR, selector))
                )
                return element
            except TimeoutException as exc:
                last_error = exc
        time.sleep(1)
    raise SystemExit(f"could not find a clickable element for selectors: {selectors}\n{last_error}")


def update_meta(profile: str, action: str, session: dict | None = None) -> None:
    meta = load_meta(profile) or {"profile": sanitize_profile(profile)}
    meta["browser_dir"] = str(profile_browser_dir(profile))
    meta["last_action"] = action
    meta["updated_at"] = now()
    if session is not None:
        meta["session"] = session
    save_meta(profile, meta)


def keep_window_open(driver: webdriver.Firefox) -> None:
    print("browser is still open. Press Enter here to close it.", flush=True)
    try:
        input()
    except EOFError:
        time.sleep(30)


def ensure_session_via_browser(profile: str, keep_open: bool, headless: bool) -> None:
    if headless:
        raise SystemExit("headless auth is not supported. Run `xit auth <profile>` without --headless.")
    print("opening normal Firefox for login", flush=True)
    print("log in there, then close Firefox and press Enter here", flush=True)
    proc = launch_manual_firefox(profile, LOGIN_URL)
    try:
        input()
    except EOFError:
        pass

    if proc.poll() is None:
        print(
            "Firefox is still running. Close it so the profile lock is released, then press Enter.",
            flush=True,
        )
        try:
            input()
        except EOFError:
            pass

    driver = build_driver(profile, headless=False)
    try:
        wait_for_login(driver, profile, 20, allow_manual_login=False)
        update_meta(profile, "auth")
        print(f"session ready for {profile}")
        print(f"profile cache: {profile_root(profile)}")
        if keep_open:
            keep_window_open(driver)
    finally:
        driver.quit()


def ensure_session(
    profile: str,
    keep_open: bool,
    headless: bool,
    manual_browser: bool,
    auth_bind: str,
    auth_port: int,
    auth_timeout: int,
) -> None:
    if manual_browser:
        ensure_session_via_browser(profile, keep_open=keep_open, headless=headless)
        return

    if keep_open:
        print("ignoring --keep-open for localhost auth capture", flush=True)
    if headless:
        print("`--headless` is implied for localhost auth capture", flush=True)

    capture = capture_session_via_localhost(
        profile,
        host=auth_bind,
        port=auth_port,
        timeout_seconds=auth_timeout,
    )

    print("verifying the captured session in headless Firefox", flush=True)
    driver = build_driver(profile, headless=True)
    try:
        wait_for_login(driver, profile, 20, allow_manual_login=False, session_payload=capture)
    finally:
        driver.quit()

    update_meta(profile, "auth", session=capture)
    print(f"session ready for {profile}")
    print(f"profile cache: {profile_root(profile)}")


def post_text(profile: str, text: str, keep_open: bool, headless: bool) -> None:
    if headless and keep_open:
        print("ignoring --keep-open in headless mode")
        keep_open = False
    driver = build_driver(profile, headless=headless)
    try:
        wait_for_login(
            driver,
            profile,
            LOGIN_TIMEOUT_SECONDS,
            allow_manual_login=not headless,
        )
        driver.get(COMPOSE_URL)
        textbox = wait_clickable(
            driver,
            [
                "[data-testid='tweetTextarea_0']",
                "div[role='textbox'][data-testid='tweetTextarea_0']",
                "div[role='textbox']",
            ],
            POST_TIMEOUT_SECONDS,
        )
        textbox.click()
        driver.execute_script("arguments[0].textContent = '';", textbox)
        textbox.send_keys(text)

        post_button = wait_clickable(
            driver,
            [
                "[data-testid='tweetButton']",
                "[data-testid='tweetButtonInline']",
            ],
            POST_TIMEOUT_SECONDS,
        )
        post_button.click()

        time.sleep(3)
        update_meta(profile, "post")
        print(f"posted as {profile}")
        if keep_open:
            keep_window_open(driver)
    finally:
        driver.quit()


def show_profile(profile: str) -> None:
    meta = load_meta(profile) or {}
    session = meta.get("session") if isinstance(meta.get("session"), dict) else {}
    root = profile_root(profile)
    browser = profile_browser_path(profile)
    summary = {
        "profile": sanitize_profile(profile),
        "profile_root": str(root),
        "browser_dir": str(browser),
        "has_cached_session": browser.exists(),
        "has_cached_meta": bool(meta),
        "has_stored_session": bool(session.get("cookies")),
        "last_action": meta.get("last_action"),
        "session_cookie_count": len(session.get("cookies", [])),
        "session_captured_at": session.get("captured_at"),
        "session_source": session.get("source"),
        "updated_at": meta.get("updated_at"),
    }
    print(json.dumps(summary, indent=2, sort_keys=True))


def list_profiles() -> None:
    root = resolve_profiles_root()
    found = sorted([p.name for p in root.iterdir() if p.is_dir()])
    if not found:
        print("no cached profiles")
        return
    for item in found:
        print(item)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="xit",
        description="Use a persistent Firefox profile or imported X session and post through the web UI.",
    )
    parser.add_argument("profile", nargs="?", help="profile label, usually the X username")
    parser.add_argument("--post", dest="post_text_value", help="publish a post through the X web UI")
    parser.add_argument(
        "--keep-open",
        action="store_true",
        help="leave the browser open after auth/post",
    )
    parser.add_argument(
        "--headless",
        action="store_true",
        help="reuse a cached Firefox or imported session in headless Firefox",
    )
    return parser


def main(argv: list[str]) -> int:
    if argv and argv[0] == "list":
        list_profiles()
        return 0

    if argv and argv[0] == "logout":
        parser = argparse.ArgumentParser(prog="xit logout", description="remove a cached browser profile")
        parser.add_argument("profile")
        args = parser.parse_args(argv[1:])
        delete_profile(args.profile)
        print(f"removed cached profile for {args.profile}")
        return 0

    if argv and argv[0] == "nickname":
        parser = argparse.ArgumentParser(prog="xit nickname", description="rename a cached browser profile")
        parser.add_argument("old_profile")
        parser.add_argument("new_profile")
        args = parser.parse_args(argv[1:])
        rename_profile(args.old_profile, args.new_profile)
        print(f"renamed cached profile {args.old_profile} -> {args.new_profile}")
        return 0

    if argv and argv[0] == "auth":
        parser = argparse.ArgumentParser(
            prog="xit auth",
            description="capture an X session via localhost and cache it for reuse",
        )
        parser.add_argument("profile")
        parser.add_argument("--keep-open", action="store_true")
        parser.add_argument("--headless", action="store_true")
        parser.add_argument(
            "--manual-browser",
            action="store_true",
            help="use the old visible-browser auth flow instead of the localhost capture server",
        )
        parser.add_argument(
            "--bind",
            default=AUTH_CAPTURE_HOST,
            help=f"bind host for the localhost auth page (default: {AUTH_CAPTURE_HOST})",
        )
        parser.add_argument(
            "--port",
            type=int,
            default=AUTH_CAPTURE_PORT,
            help=f"bind port for the localhost auth page (default: {AUTH_CAPTURE_PORT})",
        )
        parser.add_argument(
            "--timeout",
            type=int,
            default=AUTH_CAPTURE_TIMEOUT_SECONDS,
            help=f"seconds to wait for the localhost auth submission (default: {AUTH_CAPTURE_TIMEOUT_SECONDS})",
        )
        args = parser.parse_args(argv[1:])
        ensure_session(
            args.profile,
            keep_open=args.keep_open,
            headless=args.headless,
            manual_browser=args.manual_browser,
            auth_bind=args.bind,
            auth_port=args.port,
            auth_timeout=args.timeout,
        )
        return 0

    parser = build_parser()
    args = parser.parse_args(argv)
    if not args.profile:
        parser.print_help(sys.stderr)
        return 2

    if args.post_text_value:
        post_text(args.profile, args.post_text_value, keep_open=args.keep_open, headless=args.headless)
        return 0

    show_profile(args.profile)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
